@model WebAvanzadaIICuatrimestre.BLL.Dtos.DuennoDto

<div class="modal fade" id="modalEditarDuenno" tabindex="-1" aria-labelledby="modalEditarDuenno" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalEditarDuenno">Editar Dueño</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formEditarDuenno" asp-action="UpdateDuenno" asp-controller="Duenno" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label">Nombre</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Edad" class="form-label">Edad</label>
                        <input asp-for="Edad" type="number" min="0" class="form-control" />
                        <span asp-validation-for="Edad" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Apellido1" class="form-label">Apellido 1</label>
                        <input asp-for="Apellido1" class="form-control" />
                        <span asp-validation-for="Apellido1" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Apellido2" class="form-label">Apellido 2</label>
                        <input asp-for="Apellido2" class="form-control" />
                        <span asp-validation-for="Apellido2" class="text-danger"></span>
                    </div>

    
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" id="btnEditarDuenno">Editar Dueño</button>
            </div>
        </div>
    </div>
</div>










@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
