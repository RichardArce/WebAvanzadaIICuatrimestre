@using WebAvanzadaIICuatrimestre.BLL.Dtos;
@model List<DuennoDto>
@{
    ViewData["Title"] = "Mantenimiento de Dueños";
}

<link rel="stylesheet" href="~/css/duenno.css" asp-append-version="true" />

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h2 class="mb-0">Lista de Dueños</h2>
            <div>
                <button type="button" class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#modalCrearDuenno">
                    Crear Dueño
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="tblDuenno" class="table table-hover table-bordered align-middle" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th style="width:6%">Id</th>
                            <th>Nombre</th>
                            <th style="width:8%">Edad</th>
                            <th>Apellido1</th>
                            <th>Apellido2</th>
                            <th style="width:18%">Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_Editar") @* Esto es para incluir el modal de editar dueño en esta vista. *@
    @await Html.PartialAsync("_Crear") @* Esto es para incluir el modal de crear dueño en esta vista. *@

</div>




@section Scripts {
    <partial name="_ValidationScriptsPartial" /> @* Esto es importante por que tiene los metodos para validacion de jquery *@
    <script src="~/js/duenno.js" asp-append-version="true"></script> @* Cada vez que se haga cambios en el JS se genera un archivo nuevo con un hash en el nombre para evitar problemas de cacheo en el navegador. *@
}



