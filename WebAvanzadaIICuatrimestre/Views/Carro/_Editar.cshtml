@model WebAvanzadaIICuatrimestre.BLL.Dtos.CarroDto

<div class="modal fade" id="modalEditarCarro" tabindex="-1" aria-labelledby="labelModalEditarCarro" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">

            <div class="modal-header text-white" style="background: linear-gradient(135deg, #2563eb 0%, #4f46e5 100%);">
                <h5 class="modal-title fw-semibold" id="labelModalEditarCarro">
                    <i class="bi bi-pencil-square me-2"></i>Editar Carro
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">
                <form id="formEditarCarro" asp-action="UpdateCarro" asp-controller="Carro" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="col-md-6">
                        <label asp-for="Placa" class="form-label fw-medium">
                            <i class="bi bi-card-text text-primary me-1"></i>Placa
                        </label>
                        <input asp-for="Placa" class="form-control" />
                        <span asp-validation-for="Placa" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Marca" class="form-label fw-medium">
                            <i class="bi bi-tag text-primary me-1"></i>Marca
                        </label>
                        <input asp-for="Marca" class="form-control" />
                        <span asp-validation-for="Marca" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ValorFiscal" class="form-label fw-medium">
                            <i class="bi bi-currency-dollar text-primary me-1"></i>Valor Fiscal
                        </label>
                        <input asp-for="ValorFiscal" type="number" step="0.01" min="0" class="form-control" />
                        <span asp-validation-for="ValorFiscal" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Chocado" class="form-label fw-medium">
                            <i class="bi bi-exclamation-triangle text-primary me-1"></i>Chocado
                        </label>
                        <select asp-for="Chocado" class="form-select">
                            <option value="">-- Seleccione --</option>
                            <option value="0">No</option>
                            <option value="1">Sí</option>
                        </select>
                        <span asp-validation-for="Chocado" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Fkduenno" class="form-label fw-medium">
                            <i class="bi bi-person text-primary me-1"></i>Dueño
                        </label>
                        <select asp-for="Fkduenno" class="form-select">
                            <option value="">-- Seleccione dueño --</option>
                            @if (ViewBag.Duennos != null)
                            {
                                foreach (var d in ViewBag.Duennos)
                                {
                                    <option value="@d.Id">@d.Nombre</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="Fkduenno" class="text-danger small"></span>
                    </div>

                </form>
            </div>

            <div class="modal-footer border-top px-4 py-3">
                <button type="button" class="btn btn-light border" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cerrar
                </button>
                <button type="button" class="btn btn-primary" id="btnEditarCarro">
                    <i class="bi bi-floppy me-1"></i>Guardar cambios
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
